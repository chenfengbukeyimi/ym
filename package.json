{
  "name": "ym",
  "version": "0.0.1",
  "description": "A starter for creating a TypeScript package.",
  "homepage": "hhttps://github.com/chenfengbukeyimi/ym#readme",
  "bugs": {
    "url": "hhttps://github.com/chenfengbukeyimi/ym/issues"
  },
  "license": "MIT",
  "author": "Author Name <author.name@mail.com>",
  "repository": {
    "type": "git",
    "url": "git+hhttps://github.com/chenfengbukeyimi/ym.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "word:check": "cspell lint **/*.{ts,md,json} --no-progress --config ./cspell.config.mts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitest/coverage-v8": "4.1.9",
    "bumpp": "^11.1.0",
    "cspell": "^10.0.1",
    "typescript": "^6.0.3",
    "vite-plus": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  }
}
